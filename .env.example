# Dragon Market — environment configuration
# Copy to .env and adjust as needed.

# HTTP server listen address.
HTTP_ADDR=:8080

# PostgreSQL connection (used from Phase 1 onward).
# Inside docker-compose the host is "postgres"; locally it is "localhost".
DATABASE_URL=postgres://dragon:dragon@localhost:5432/dragon_market?sslmode=disable

# Auction timing (configurable). Defaults are demo-friendly so the 5-minute
# anti-snipe extension is easy to see; the spec suggests a 24h window.
AUCTION_WINDOW=6m
AUCTION_EXTENSION=5m
